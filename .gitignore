# Visual Studio
.vs/
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
.vsconfig
*.vcxproj
*.vcxproj.filters
*.sln

# Compiled output
Binaries/
Plugins/**/Binaries/
Build/
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# Intermediate / cache
Intermediate/
Plugins/**/Intermediate/
DerivedDataCache/
Saved/

# Compiled object / library files
*.slo *.lo *.o *.obj
*.gch *.pch
*.so *.dylib *.dll
*.mod
*.lai *.la *.a *.lib
*.exe *.out *.app *.ipa

# Unreal built data
*_BuiltData.uasset

# Precompiled assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Xcode
*.xcodeproj
*.xcworkspace

# Content — track source assets only, not cooked output
Content/Collections/
Content/__ExternalActors__/
Content/__ExternalObjects__/
